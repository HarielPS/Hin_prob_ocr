# app/ocr/context_builder.py

from __future__ import annotations
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Dict, List, Optional

from app.ocr.ocr_service import (
    load_page_image,
    crop_bbox,
    crop_top_half,
    crop_bottom_half,
    ocr_tesseract,
    OCRResult,
)


@dataclass
class ContextOCR:
    region_text: str
    region_conf: Optional[float]
    context_text: str
    context_conf: Optional[float]
    headers_text: str
    headers_conf: Optional[float]
    text_for_llm: str
    pages_used: List[int]
    debug: Dict[str, Any]


def _is_near_top(bbox: Dict[str, int], img_h: int, threshold: float = 0.15) -> bool:
    return bbox["y1"] <= int(img_h * threshold)


def _is_near_bottom(bbox: Dict[str, int], img_h: int, threshold: float = 0.85) -> bool:
    return bbox["y2"] >= int(img_h * threshold)


def _looks_like_table(region_text: str) -> bool:
    """
    Heurística MVP:
    - muchas líneas
    - presencia de múltiples separadores/valores por línea
    - o números repetidos y tokens cortos
    """
    lines = [ln.strip() for ln in region_text.splitlines() if ln.strip()]
    if len(lines) >= 4:
        # si varias líneas tienen 2+ "columnas" (separadas por múltiples espacios)
        col_like = sum(1 for ln in lines if "  " in ln or "\t" in ln)
        if col_like >= max(2, len(lines) // 2):
            return True
    return False


def _find_headers_in_text(page_text: str) -> str:
    """
    MVP simple: toma las primeras N líneas “densas” como headers candidatos.
    Luego lo mejoramos con detección de tabla.
    """
    lines = [ln.strip() for ln in page_text.splitlines() if ln.strip()]
    return "\n".join(lines[:12])


def build_context_for_llm(
    file_path: str,
    page_index: int,
    bbox: Dict[str, int],
    dpi: int = 220,
    lang: str = "spa",
    max_header_pages_back: int = 3,
) -> ContextOCR:
    """
    1) OCR bbox (region)
    2) OCR contexto (media página anterior/siguiente si bbox near top/bottom)
    3) Si parece tabla: buscar headers hacia atrás (hasta N páginas) y pegarlos
    4) Construir text_for_llm
    5) Debug print (lo que mandas)
    """
    # Page image (selected)
    page_img = load_page_image(file_path, page_index, dpi=dpi)
    w, h = page_img.size

    # 1) region OCR
    region_img = crop_bbox(page_img, bbox)
    region_res = ocr_tesseract(region_img, lang=lang)

    # 2) context OCR (prev/next half)
    context_chunks: List[str] = []
    context_confs: List[float] = []
    pages_used = [page_index]

    near_top = _is_near_top(bbox, h)
    near_bottom = _is_near_bottom(bbox, h)

    # Si está cerca del top, intenta traer bottom half de página anterior
    if near_top and page_index > 0 and Path(file_path).suffix.lower() == ".pdf":
        prev_img = load_page_image(file_path, page_index - 1, dpi=dpi)
        prev_bottom = crop_bottom_half(prev_img)
        prev_res = ocr_tesseract(prev_bottom, lang=lang)
        context_chunks.append("[CTX_PREV_BOTTOM]\n" + prev_res.text)
        if prev_res.mean_conf is not None:
            context_confs.append(prev_res.mean_conf)
        pages_used.append(page_index - 1)

    # Si está cerca del bottom, intenta traer top half de página siguiente
    if near_bottom and Path(file_path).suffix.lower() == ".pdf":
        # ojo: no sabemos total páginas aquí (pdf2image parcial), MVP: intenta y atrapa error
        try:
            next_img = load_page_image(file_path, page_index + 1, dpi=dpi)
            next_top = crop_top_half(next_img)
            next_res = ocr_tesseract(next_top, lang=lang)
            context_chunks.append("[CTX_NEXT_TOP]\n" + next_res.text)
            if next_res.mean_conf is not None:
                context_confs.append(next_res.mean_conf)
            pages_used.append(page_index + 1)
        except Exception:
            pass

    context_text = "\n\n".join([c for c in context_chunks if c.strip()])
    context_conf = (sum(context_confs) / len(context_confs)) if context_confs else None

    # 3) headers/table logic
    headers_text = ""
    headers_conf = None
    looks_table = _looks_like_table(region_res.text)

    if looks_table and Path(file_path).suffix.lower() == ".pdf":
        # Busca headers hacia atrás (MVP: OCR page completa y tomar primeras líneas)
        best_headers = ""
        best_conf = -1.0
        used_pages = []

        for back in range(0, max_header_pages_back + 1):
            idx = page_index - back
            if idx < 0:
                break
            img = load_page_image(file_path, idx, dpi=dpi)
            full_res = ocr_tesseract(img, lang=lang)
            cand = _find_headers_in_text(full_res.text)
            conf = full_res.mean_conf or 0.0

            # Heurística: si hay “más letras” en primeras líneas, puede ser encabezado
            score = conf + (0.1 * len(cand))
            if score > best_conf:
                best_conf = score
                best_headers = cand
                headers_conf = full_res.mean_conf
                used_pages = [idx]

        headers_text = best_headers
        pages_used += used_pages

    # 4) construir text_for_llm
    parts = []
    parts.append("=== REGION_OCR ===\n" + (region_res.text or ""))
    if headers_text.strip():
        parts.append("=== TABLE_HEADERS (FOUND) ===\n" + headers_text)
    if context_text.strip():
        parts.append("=== CONTEXT ===\n" + context_text)

    text_for_llm = "\n\n".join(parts).strip()

    debug = {
        "near_top": near_top,
        "near_bottom": near_bottom,
        "looks_table": looks_table,
        "bbox": bbox,
    }

    return ContextOCR(
        region_text=region_res.text,
        region_conf=region_res.mean_conf,
        context_text=context_text,
        context_conf=context_conf,
        headers_text=headers_text,
        headers_conf=headers_conf,
        text_for_llm=text_for_llm,
        pages_used=sorted(list(set(pages_used))),
        debug=debug,
    )

