3) Implementación: app/ocr/ocr_service.py

Crea este archivo:

# app/ocr/ocr_service.py

from __future__ import annotations
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Optional, Tuple

import pytesseract
from PIL import Image, ImageOps
from pdf2image import convert_from_path


@dataclass
class OCRResult:
    text: str
    mean_conf: Optional[float] = None


def render_pdf_page(pdf_path: str, page_index: int, dpi: int = 220) -> Image.Image:
    pages = convert_from_path(
        pdf_path,
        dpi=dpi,
        first_page=page_index + 1,
        last_page=page_index + 1,
    )
    if not pages:
        raise ValueError("No se pudo renderizar la página del PDF.")
    return pages[0].convert("RGB")


def load_image(file_path: str) -> Image.Image:
    return Image.open(file_path).convert("RGB")


def load_page_image(file_path: str, page_index: int, dpi: int = 220) -> Image.Image:
    p = Path(file_path)
    ext = p.suffix.lower()
    if ext == ".pdf":
        return render_pdf_page(str(p), page_index, dpi=dpi)
    if ext in {".png", ".jpg", ".jpeg"}:
        return load_image(str(p))
    raise ValueError(f"Formato no soportado para OCR: {ext}")


def crop_bbox(img: Image.Image, bbox: Dict[str, int]) -> Image.Image:
    return img.crop((bbox["x1"], bbox["y1"], bbox["x2"], bbox["y2"]))


def crop_top_half(img: Image.Image) -> Image.Image:
    w, h = img.size
    return img.crop((0, 0, w, h // 2))


def crop_bottom_half(img: Image.Image) -> Image.Image:
    w, h = img.size
    return img.crop((0, h // 2, w, h))


def preprocess(img: Image.Image) -> Image.Image:
    # MVP: gris + autocontrast
    g = ImageOps.grayscale(img)
    g = ImageOps.autocontrast(g)
    return g


def ocr_tesseract(img: Image.Image, lang: str = "spa") -> OCRResult:
    proc = preprocess(img)
    data = pytesseract.image_to_data(proc, lang=lang, output_type=pytesseract.Output.DICT)

    words = []
    confs = []
    n = len(data.get("text", []))

    for i in range(n):
        txt = (data["text"][i] or "").strip()
        try:
            conf = float(data["conf"][i])
        except Exception:
            conf = -1.0

        if txt:
            words.append(txt)
        if conf >= 0:
            confs.append(conf)

    text = " ".join(words).strip()
    mean_conf = (sum(confs) / len(confs)) if confs else None
    return OCRResult(text=text, mean_conf=mean_conf)

