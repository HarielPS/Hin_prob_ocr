# app/api/routes_rules.py

import json
import os
import tempfile
from pathlib import Path
from typing import Optional, Any, Dict

from fastapi import APIRouter, UploadFile, File, Form, Depends, Request, HTTPException
from langchain_core.language_models.chat_models import BaseChatModel

from app.llm.providers import get_chat_model
from app.pipelines.rules_pipeline import generate_rule_pipeline

router = APIRouter()

SUPPORTED_EXT = {".pdf", ".png", ".jpg", ".jpeg"}  # doc/docx después (convertir a pdf)
CHUNK_SIZE = 1024 * 1024  # 1MB


def _safe_suffix(filename: Optional[str]) -> str:
    if not filename:
        return ""
    return Path(filename).suffix.lower()


def _save_upload_to_temp_streaming(upload: UploadFile) -> str:
    """
    Guarda UploadFile a un temp file sin cargarlo completo en RAM (streaming).
    """
    suffix = _safe_suffix(upload.filename)
    if suffix and suffix not in SUPPORTED_EXT:
        raise HTTPException(
            status_code=400,
            detail=f"Formato no soportado: {suffix}. Soportados: {sorted(SUPPORTED_EXT)}",
        )

    # Crear temp file con extensión (para que OCR sepa qué es)
    fd, tmp_path = tempfile.mkstemp(suffix=suffix)
    os.close(fd)

    try:
        with open(tmp_path, "wb") as out:
            while True:
                chunk = upload.file.read(CHUNK_SIZE)
                if not chunk:
                    break
                out.write(chunk)
        return tmp_path
    except Exception as e:
        # Si falla, intenta limpiar
        try:
            Path(tmp_path).unlink(missing_ok=True)
        except Exception:
            pass
        raise HTTPException(status_code=500, detail=f"Error guardando archivo temporal: {e}")


@router.post("/rules/generate")
async def rules_generate(
    request: Request,
    file: UploadFile = File(...),
    region: str = Form(...),
    field_title: Optional[str] = Form(""),
    model: BaseChatModel = Depends(get_chat_model),
):
    """
    Genera una regla:
    input: file + region(JSON string) + field_title
    output: {rule, region_payload, ocr{...}}
    """
    # 1) Parse region JSON string
    try:
        region_payload: Dict[str, Any] = json.loads(region)
    except Exception:
        raise HTTPException(status_code=400, detail="region debe ser JSON válido (string).")

    # Validaciones mínimas de region para evitar errores raros
    if "page_index" not in region_payload or "bbox" not in region_payload:
        raise HTTPException(status_code=400, detail="region debe incluir page_index y bbox.")

    # 2) Guardar archivo grande a temp por streaming
    tmp_path = _save_upload_to_temp_streaming(file)

    try:
        # 3) Pipeline completo (OCR + contexto + LLM)
        resp = generate_rule_pipeline(
            file_path=tmp_path,
            region_payload=region_payload,
            field_title=field_title or "",
            model=model,  # inyectado por FastAPI
        )
        return resp

    finally:
        # Limpieza del temp (en prod sí; para debug puedes comentar)
        try:
            Path(tmp_path).unlink(missing_ok=True)
        except Exception:
            pass
